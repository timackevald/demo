{
  "system": {
    "version": "1.0",
    "name": "Sunspots Daemon",
    "log_path": "./logs/daemon.log",
    "socket_path": "./logs/sunspots.sock",
    "location": {
      "name": "Stockholm",
      "latitude": 59.3293,
      "longitude": 18.0686,
      "elprisomrade": "SE3"
    }
  },
  "sdk": {
    "db_dir": "db/ss_sdk.db",
    "log_level": "info",
    "log_mirror_enabled": true,
    "log_mirror_path": "logs/sdk.log",
    "log_mirror_max_bytes": "5242880"
  },
  "modules": [
    {
      "name": "Logger",
      "bin_path": "./build/debug/src/core/sunspots_logger",
      "Timer-type": 0,
      "heartbeat_interval": 3,
      "log_path": "./logs/daemon.log"
    },
    {
      "name": "Elprisjustnu",
      "bin_path": "./build/debug/src/fetch/apis/sunspots_fetch_elprisjustnu",
      "Timer-type": 1,
      "Rek-time": 50
    },
    {
      "name": "ComputeManager",
      "bin_path": "./build/debug/src/compute/sunspots_compute_manager",
      "Timer-type": 1,
      "Rel-time": 60
    },
    {
      "name": "Openmeteo",
      "bin_path": "./build/debug/src/fetch/apis/sunspots_fetch_openmeteo",
      "Timer-type": 1,
      "Rel-time": 30
    },
    {
      "name": "Openmeteo_forecast",
      "bin_path": "./build/debug/src/fetch/apis/sunspots_fetch_openmeteo_forecast",
      "Timer-type": 1,
      "Rel-time": 100
    },
    {
      "name": "BackfillOpenMeteo",
      "bin_path": "./build/debug/src/backfill/sunspots_backfill_openmeteo",
      "Timer-type": 1,
      "Rel-time": 86400,
      "start_immediately": true,
      "backfill": {
        "enabled": true,
        "required_history_days": 14,
        "chunk_days": 7,
        "retry_max_attempts": 5,
        "retry_base_backoff_ms": 1000,
        "freshness_lag_minutes": 120,
        "request_interval_ms": 250,
        "max_requests_per_minute": 240,
        "max_requests_per_hour": 2000,
        "max_requests_per_day": 8000,
        "progress_log_interval_sec": 10
      }
    },
    {
      "name": "Frontend",
      "bin_path": "./build/debug/src/frontend/sunspots_frontend",
      "Timer-type": 0,
      "heartbeat_interval": 4,
      "server_threads": 8,
      "server_port_http": 10480,
      "server_port_https": null,
      "server_listen_queue": 16,
      "client_queue_size": 32,
      "allow_file_search": true,
      "file_search_dir": "./",
      "aliases": [
        {
          "target_url": "/README",
          "target_file": "./README.md"
        }
      ]
    }
  ]
}
